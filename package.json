{
  "name": "address-book",
  "version": "1.0.6",
  "description": "Address Book desktop application — Electron + React + SQLite with multi-format import and LinkedIn integration",
  "author": "anndunkin",
  "license": "MIT",
  "main": "dist/main/index.js",
  "scripts": {
    "build:main": "webpack --config webpack.main.config.js --mode production",
    "build:renderer": "webpack --config webpack.renderer.config.js --mode production",
    "build": "npm run build:main && npm run build:renderer",
    "dev:main": "webpack --config webpack.main.config.js --mode development",
    "dev:renderer": "webpack serve --config webpack.renderer.config.js --mode development",
    "start": "npm run build:main && electron .",
    "dist": "npm run build && electron-builder",
    "test": "jest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "electron-store": "^8.2.0",
    "papaparse": "^5.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.0.1",
    "@types/better-sqlite3": "^7.6.11",
    "@types/jest": "^29.5.12",
    "@types/papaparse": "^5.3.14",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "css-loader": "^7.1.2",
    "electron": "^31.4.0",
    "electron-builder": "^24.13.3",
    "html-webpack-plugin": "^5.6.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "style-loader": "^4.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "typescript": "^5.5.4",
    "webpack": "^5.94.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.1.0"
  }
}
